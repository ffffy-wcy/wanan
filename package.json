{
  "name": "goodnight",
  "version": "1.0.0",
  "description": "goodnight · 面向情侣的陪伴与守护 App",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build": "npx prisma generate",
    "postinstall": "npx prisma generate",
    "test": "node scripts/smoke-email-auth.js && node scripts/smoke-ui.js",
    "test:api": "node scripts/smoke-email-auth.js",
    "test:ui": "node scripts/smoke-ui.js",
    "sync:www": "node scripts/sync-www.js",
    "db:migrate": "npx prisma migrate deploy",
    "db:migrate:dev": "npx prisma migrate dev --name init",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android"
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "nodemailer": "^6.10.1",
    "playwright": "^1.61.0",
    "resend": "^6.14.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}

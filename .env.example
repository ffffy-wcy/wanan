# Database (Render/Supabase/Neon/PostgreSQL)
# The current Prisma provider is postgresql. DATABASE_URL must start with
# postgresql:// or postgres://.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
JWT_SECRET="YOUR_VALUE_HERE"
JWT_REFRESH_SECRET="YOUR_VALUE_HERE"
PORT=3000
APP_NAME="goodnight"

# QQ login (pending third-party review)
QQ_APP_ID="YOUR_VALUE_HERE"
QQ_APP_KEY="YOUR_VALUE_HERE"
QQ_REDIRECT_URI="YOUR_REDIRECT_URI_HERE"

# Email verification (SendGrid)
SENDGRID_API_KEY="YOUR_SENDGRID_API_KEY_HERE"
SENDER_EMAIL="YOUR_VERIFIED_SENDER_EMAIL@example.com"

# Email verification fallback (Resend)
RESEND_API_KEY="YOUR_RESEND_API_KEY_HERE"
RESEND_FROM="onboarding@resend.dev"

# Email verification fallback (legacy SMTP, for example a QQ Mail auth code)
SMTP_HOST="smtp.qq.com"
SMTP_PORT="465"
SMTP_USER="YOUR_EMAIL@qq.com"
SMTP_PASS="YOUR_SMTP_AUTH_CODE_HERE"
SMTP_FROM="YOUR_EMAIL@qq.com"
